# Firebase Web Config (public, nhung van dat trong env de de doi giua cac moi truong)
# Lay tu Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY="AIzaSyCoL-hjSnLUDnqXgJmH0bIEaduwFQ7pr7k"
VITE_FIREBASE_AUTH_DOMAIN="edumatrix-vn-576b1.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="edumatrix-vn-576b1"
VITE_FIREBASE_STORAGE_BUCKET="edumatrix-vn-576b1.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="87387037612"
VITE_FIREBASE_APP_ID="1:87387037612:web:a989627388655e1c8aa409"
VITE_FIREBASE_MEASUREMENT_ID="G-HMLQJQJE1S"

# Firebase App Check (reCAPTCHA v3 site key)
VITE_APPCHECK_SITE_KEY=6Lf9i00tAAAAANLcCyqiHp24_bcz_XTHwZl3CnaT
VITE_MESSENGER_WORKER_URL=
# Facebook Page username (vd trong link facebook.com/<ten-nay>) - dung de tao link
# m.me/<page>?ref=<nonce> mot lan qua Worker; khong dua Firebase UID vao URL.
# De trong neu chua co Page - tinh nang lien quan se tu an.
VITE_MESSENGER_PAGE_USERNAME=

# Google Drive cho giao an (deu la dinh danh public; gioi han API key theo origin)
# Bat Google Drive API + Google Picker API, cau hinh OAuth Web authorized origins.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_PICKER_API_KEY=
# Project number (khong phai project ID), dung cho Google Picker setAppId().
VITE_GOOGLE_PICKER_APP_ID=

# Chi dung khi chay local (không commit token thật)
VITE_APPCHECK_DEBUG_TOKEN=

# --- Test local voi Firebase Emulator ---
# Dat = true de app ket noi Auth(9099)+Firestore(8090) emulator thay vi project that.
# Khi bat: dat VITE_FIREBASE_PROJECT_ID="demo-edumatrix" (khop script seed-admin),
# cac VITE_FIREBASE_* con lai co the la gia tri gia, va de VITE_APPCHECK_SITE_KEY trong.
VITE_USE_EMULATORS=

# KHONG duoc them bat ky bien nao ben duoi day vao file .env frontend:
# GOOGLE_CLIENT_SECRET, GOOGLE_REFRESH_TOKEN, META_PAGE_ACCESS_TOKEN,
# META_APP_SECRET, META_VERIFY_TOKEN, FIREBASE service account...
# Cac secret nay chi duoc cau hinh trong Cloudflare Worker (workers/messenger), khong bao gio o client.
