{
  "name": "edumatrix-messenger-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run",
    "build:prod": "npm run check:prod-config && wrangler deploy --dry-run --env production",
    "check:prod-config": "node scripts/check-production-config.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "npm run check:prod-config && wrangler deploy --env production",
    "test": "vitest run"
  },
  "dependencies": {
    "jose": "^6.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "^5.6.2",
    "vitest": "^3.2.6",
    "wrangler": "^4.0.0"
  }
}
