# Ghi de tam thoi de tro app sang Firebase Emulator (Auth 9099 + Firestore 8090)
# thay vi project that edumatrix-vn-576b1. File nay da nam trong .gitignore.
# Muon quay lai project that: xoa file nay (hoac doi VITE_USE_EMULATORS ve rong)
# roi restart "npm run dev".
VITE_USE_EMULATORS=true
VITE_FIREBASE_PROJECT_ID=demo-edumatrix
VITE_FIREBASE_API_KEY=demo
VITE_APPCHECK_SITE_KEY=
