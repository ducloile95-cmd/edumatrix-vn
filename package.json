{
  "name": "edumatrix-vn",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run src",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run firebase/tests --maxWorkers=1\"",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "roadmap:update": "node scripts/update-roadmap-status.mjs",
    "emulators": "firebase emulators:start --only auth,firestore --project demo-edumatrix",
    "seed:admin": "node scripts/seed-admin.mjs",
    "seed:admin:account": "node scripts/seed-admin-account.mjs",
    "seed:local:full": "node scripts/seed-local-full.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.56.2",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "firebase": "^12.16.0",
    "lucide-react": "^0.445.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "firebase-tools": "^15.23.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "undici": "^6.27.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
