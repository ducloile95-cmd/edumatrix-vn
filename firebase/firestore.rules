rules_version = '2';

// EDUMATRIX-VN - Firestore Security Rules
// Nguyen tac: deny-by-default (A16.1). Day la lop bao mat chinh, khong duoc
// thay the boi UI/route guard (A4.3, A16). Rules nay se duoc mo rong dan
// theo tung Phase (A5, A30) - hien tai (Phase 1/2) chi mo users/invites.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------

    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActive() {
      return userExists() && currentUser().status == 'active';
    }

    function isAdmin() {
      return isActive() && currentUser().role == 'admin';
    }

    function isTeacher() {
      return isActive() && currentUser().role == 'teacher';
    }

    function isStaff() {
      return isAdmin() || isTeacher();
    }

    function ownsStudent(studentId) {
      return isActive() &&
        currentUser().role == 'viewer' &&
        studentId in currentUser().studentIds;
    }

    // ---------- Invite claim helpers (A16.4) ----------
    // Email phai ton tai va da duoc Google xac minh - khong tin email chua verify.

    function hasVerifiedEmail() {
      return signedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email_verified == true;
    }

    function requesterEmail() {
      return request.auth.token.email.lower();
    }

    function inviteForRequester() {
      return get(/databases/$(database)/documents/invites/$(requesterEmail())).data;
    }

    function hasActiveInvite() {
      return hasVerifiedEmail() &&
        exists(/databases/$(database)/documents/invites/$(requesterEmail())) &&
        inviteForRequester().status == 'active';
    }

    function isValidRole(role) {
      return role in ['admin', 'teacher', 'viewer'];
    }

    // ---------- users/{uid} ----------
    // Chi Admin duoc doi role/studentIds/status. Tao ho so lan dau (claim invite)
    // phai khop dung role/studentIds lay tu invite - nguoi dung khong tu chon (A16.4).

    match /users/{uid} {
      allow read: if isAdmin() || request.auth.uid == uid;

      allow create: if isAdmin() || (
        request.auth.uid == uid &&
        hasActiveInvite() &&
        request.resource.data.email == requesterEmail() &&
        request.resource.data.role == inviteForRequester().role &&
        request.resource.data.studentIds == inviteForRequester().studentIds &&
        request.resource.data.status == 'active' &&
        request.resource.data.keys().hasOnly(
          ['email', 'displayName', 'photoURL', 'role', 'studentIds', 'status', 'createdAt', 'updatedAt']
        )
      );

      allow update: if isAdmin() || (
        request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'photoURL', 'updatedAt']) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.studentIds == resource.data.studentIds &&
        request.resource.data.status == resource.data.status
      );

      allow delete: if false;
    }

    // ---------- invites/{normalizedEmail} ----------
    // Chi Admin tao/sua/xoa loi moi. Nguoi duoc moi chi duoc doc loi moi cua
    // chinh email da xac thuc, va chi duoc cap nhat status active -> claimed
    // khi claim (khong duoc tu doi role/studentIds/email cua loi moi) (A16.4).

    match /invites/{email} {
      allow read: if isAdmin() || (
        hasVerifiedEmail() && requesterEmail() == email
      );

      allow create: if isAdmin() &&
        request.resource.data.email == email &&
        isValidRole(request.resource.data.role) &&
        request.resource.data.status == 'active';

      allow update: if isAdmin() || (
        hasVerifiedEmail() &&
        requesterEmail() == email &&
        resource.data.status == 'active' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'claimedAt']) &&
        request.resource.data.status == 'claimed'
      );

      allow delete: if isAdmin();
    }

    // ---------- settings/* ----------
    // Chi Admin doc/ghi cau hinh nhay cam (A16.5). Cac module doc settings.payment
    // cong khai (thong tin ngan hang) se duoc mo rieng khi trien khai module hoc phi.

    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // ---------- audit_logs/{logId} ----------
    // Staff duoc ghi (khong duoc sua/xoa - bat bien), chi Admin duoc xem (A26).

    match /audit_logs/{logId} {
      allow read: if isAdmin();

      allow create: if isStaff() &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.keys().hasOnly(
          ['action', 'actorUid', 'actorEmail', 'targetType', 'targetId', 'meta', 'createdAt']
        );

      allow update, delete: if false;
    }

    // ---------- Mac dinh: tu choi tat ca ----------
    // Cac collection khac (students, classes, sessions, lesson_plans,
    // attendance, assignments, submissions, scores, invoices, payments,
    // announcements...) se duoc mo dan theo Phase 3-11, kem
    // Emulator test cho tung quyen truoc khi enable (A28).

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
