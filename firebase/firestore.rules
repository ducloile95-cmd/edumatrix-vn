rules_version = '2';

// EDUMATRIX-VN - Firestore Security Rules
// Nguyen tac: deny-by-default (A16.1). Day la lop bao mat chinh, khong duoc
// thay the boi UI/route guard (A4.3, A16). Rules nay se duoc mo rong dan
// theo tung Phase (A5, A30) - hien tai (Phase 1/2) chi mo users/invites.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------

    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActive() {
      return userExists() && currentUser().status == 'active';
    }

    function isAdmin() {
      return isActive() && currentUser().role == 'admin';
    }

    function isTeacher() {
      return isActive() && currentUser().role == 'teacher';
    }

    function isStaff() {
      return isAdmin() || isTeacher();
    }

    function validGeneralSettings(data) {
      return data.keys().hasOnly(['name', 'schoolYear', 'address', 'phone', 'logoUrl', 'updatedAt']) &&
        data.keys().hasAll(['name', 'schoolYear', 'address', 'phone', 'logoUrl', 'updatedAt']) &&
        data.name is string && data.name.size() <= 120 &&
        data.schoolYear is string && data.schoolYear.size() <= 30 &&
        data.address is string && data.address.size() <= 300 &&
        data.phone is string && data.phone.size() <= 30 &&
        data.logoUrl is string && data.logoUrl.size() <= 500;
    }

    function validIntegrationSettings(data) {
      return data.keys().hasOnly(['facebookPageId', 'driveFolderId', 'webhookUrl', 'updatedAt']) &&
        data.keys().hasAll(['facebookPageId', 'driveFolderId', 'webhookUrl', 'updatedAt']) &&
        data.facebookPageId is string && data.facebookPageId.size() <= 100 &&
        data.driveFolderId is string && data.driveFolderId.size() <= 200 &&
        data.webhookUrl is string && data.webhookUrl.size() <= 500;
    }

    function validPaymentSettings(data) {
      return data.keys().hasOnly(['bankBin', 'bankName', 'accountNumber', 'accountName', 'contentTemplate', 'vietQrTemplate', 'updatedAt']) &&
        data.keys().hasAll(['bankBin', 'bankName', 'accountNumber', 'accountName', 'contentTemplate', 'vietQrTemplate', 'updatedAt']) &&
        data.bankBin is string && data.bankBin.matches('^[0-9]{6}$') &&
        data.bankName is string && data.bankName.size() <= 100 &&
        data.accountNumber is string && data.accountNumber.matches('^[A-Za-z0-9]{6,19}$') &&
        data.accountName is string && data.accountName.size() >= 5 && data.accountName.size() <= 50 &&
        data.contentTemplate is string && data.contentTemplate.size() <= 50 &&
        data.vietQrTemplate is string && data.vietQrTemplate.size() >= 2 && data.vietQrTemplate.size() <= 60;
    }

    function validAcademicSettings(data) {
      return data.keys().hasOnly(['rankThresholds', 'updatedAt']) &&
        data.keys().hasAll(['rankThresholds', 'updatedAt']) &&
        data.updatedAt is timestamp &&
        data.rankThresholds.keys().hasOnly(['S', 'A', 'B', 'D']) &&
        data.rankThresholds.keys().hasAll(['S', 'A', 'B', 'D']) &&
        data.rankThresholds.S is number && data.rankThresholds.S <= 100 &&
        data.rankThresholds.S > data.rankThresholds.A &&
        data.rankThresholds.A > data.rankThresholds.B &&
        data.rankThresholds.B > data.rankThresholds.D &&
        data.rankThresholds.D == 0;
    }

    function isAssignedTeacherForClass(classId) {
      return isTeacher() &&
        exists(/databases/$(database)/documents/classes/$(classId)) &&
        request.auth.uid in get(/databases/$(database)/documents/classes/$(classId)).data.teacherIds;
    }

    function canManageClass(classId) {
      return isAdmin() || isAssignedTeacherForClass(classId);
    }

    function keepsImmutable(fieldNames) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fieldNames);
    }

    function ownsStudent(studentId) {
      return isActive() &&
        currentUser().role == 'viewer' &&
        studentId in currentUser().studentIds;
    }

    function isAssignedTeacherForStudent(studentId) {
      return isTeacher() &&
        exists(/databases/$(database)/documents/students/$(studentId)) &&
        request.auth.uid in get(/databases/$(database)/documents/students/$(studentId)).data.teacherIds;
    }

    function isTeacherEnrollmentClassUpdate(classId) {
      let addedStudentIds = request.resource.data.studentIds.removeAll(resource.data.studentIds);
      return isTeacher() && request.auth.uid in resource.data.teacherIds &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds', 'updatedAt']) &&
        request.resource.data.teacherIds == resource.data.teacherIds &&
        request.resource.data.studentIds.hasAll(resource.data.studentIds) &&
        request.resource.data.studentIds.size() == resource.data.studentIds.size() + 1 &&
        addedStudentIds.size() == 1;
    }

    function isTeacherEnrollmentStudentUpdate(studentId) {
      let addedClassIds = request.resource.data.currentClassIds.removeAll(resource.data.currentClassIds);
      let classData = get(/databases/$(database)/documents/classes/$(addedClassIds[0])).data;
      return isTeacher() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentClassIds', 'teacherIds', 'updatedAt']) &&
        request.resource.data.currentClassIds.hasAll(resource.data.currentClassIds) &&
        request.resource.data.currentClassIds.size() == resource.data.currentClassIds.size() + 1 &&
        addedClassIds.size() == 1 &&
        request.auth.uid in classData.teacherIds &&
        request.resource.data.teacherIds.hasAll(resource.data.teacherIds) &&
        request.resource.data.teacherIds.hasAll(classData.teacherIds) &&
        request.resource.data.teacherIds.removeAll(resource.data.teacherIds).hasOnly(classData.teacherIds);
    }

    function isTeacherEnrollmentCreate(enrollmentId) {
      let classId = request.resource.data.classId;
      let studentId = request.resource.data.studentId;
      let classData = get(/databases/$(database)/documents/classes/$(classId)).data;
      return isTeacher() && request.auth.uid in classData.teacherIds &&
        enrollmentId == classId + '_' + studentId &&
        request.resource.data.status == 'active' &&
        request.resource.data.courseId == classData.courseId;
    }

    // ---------- Invite claim helpers (A16.4) ----------
    // Email phai ton tai va da duoc Google xac minh - khong tin email chua verify.

    function hasVerifiedEmail() {
      return signedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email_verified == true;
    }

    function requesterEmail() {
      return request.auth.token.email.lower();
    }

    function inviteForRequester() {
      return get(/databases/$(database)/documents/invites/$(requesterEmail())).data;
    }

    function hasActiveInvite() {
      return hasVerifiedEmail() &&
        exists(/databases/$(database)/documents/invites/$(requesterEmail())) &&
        inviteForRequester().status == 'active';
    }

    function isValidRole(role) {
      return role in ['admin', 'teacher', 'viewer'];
    }

    function hasTimestamps(data) {
      return data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function isStringList(value) {
      return value is list;
    }

    function validSubjectData(subjectId, data) {
      return data.keys().hasAll(['name', 'code', 'description', 'status', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['name', 'code', 'description', 'status', 'createdAt', 'updatedAt']) &&
        data.name is string &&
        data.code == subjectId &&
        data.description is string &&
        data.status in ['active', 'archived'] &&
        hasTimestamps(data);
    }

    function validCourseData(data) {
      return data.keys().hasAll(['name', 'subjectIds', 'pricePerSession', 'tuitionFee', 'totalSessions', 'startDate', 'endDate', 'status', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['name', 'subjectIds', 'pricePerSession', 'tuitionFee', 'totalSessions', 'startDate', 'endDate', 'status', 'createdAt', 'updatedAt']) &&
        data.name is string &&
        isStringList(data.subjectIds) &&
        data.subjectIds.size() > 0 &&
        data.pricePerSession is int &&
        data.pricePerSession >= 0 &&
        data.tuitionFee is int &&
        data.tuitionFee >= 0 &&
        data.totalSessions is int &&
        data.totalSessions > 0 &&
        data.startDate is timestamp &&
        data.endDate is timestamp &&
        data.endDate >= data.startDate &&
        data.status in ['draft', 'active', 'completed'] &&
        hasTimestamps(data);
    }

    function validStudentData(studentId, data) {
      return data.keys().hasAll(['studentCode', 'fullName', 'dateOfBirth', 'parentUids', 'currentClassIds', 'teacherIds', 'status', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['studentCode', 'fullName', 'dateOfBirth', 'parentUids', 'currentClassIds', 'teacherIds', 'staffNote', 'status', 'createdAt', 'updatedAt']) &&
        data.studentCode == studentId &&
        data.fullName is string &&
        data.dateOfBirth is string &&
        isStringList(data.parentUids) &&
        isStringList(data.currentClassIds) &&
        isStringList(data.teacherIds) &&
        (!data.keys().hasAny(['staffNote']) || data.staffNote is string) &&
        data.status in ['active', 'inactive'] &&
        hasTimestamps(data);
    }

    function validRecurrence(data) {
      return data.keys().hasAll(['daysOfWeek', 'startTime', 'endTime', 'startDate', 'endDate', 'sessionCount']) &&
        data.keys().hasOnly(['daysOfWeek', 'startTime', 'endTime', 'startDate', 'endDate', 'sessionCount']) &&
        data.daysOfWeek is list &&
        data.daysOfWeek.size() > 0 &&
        data.startTime is string &&
        data.endTime is string &&
        data.startDate is timestamp &&
        data.endDate is timestamp &&
        data.endDate >= data.startDate &&
        data.sessionCount is int &&
        data.sessionCount > 0;
    }

    function validClassData(data) {
      return data.keys().hasAll(['name', 'courseId', 'subjectIds', 'teacherIds', 'studentIds', 'scheduleText', 'location', 'status', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['name', 'courseId', 'subjectIds', 'teacherIds', 'studentIds', 'scheduleText', 'location', 'status', 'recurrence', 'createdAt', 'updatedAt']) &&
        data.name is string &&
        data.courseId is string &&
        isStringList(data.subjectIds) &&
        isStringList(data.teacherIds) &&
        isStringList(data.studentIds) &&
        data.scheduleText is string &&
        data.location is string &&
        data.status in ['active', 'completed', 'cancelled'] &&
        (!data.keys().hasAny(['recurrence']) || data.recurrence == null || validRecurrence(data.recurrence)) &&
        hasTimestamps(data);
    }

    function validSessionData(data) {
      return data.keys().hasAll(['classId', 'title', 'startAt', 'endAt', 'location', 'status', 'note', 'makeUpForSessionId', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['classId', 'title', 'startAt', 'endAt', 'location', 'status', 'note', 'makeUpForSessionId', 'createdAt', 'updatedAt']) &&
        data.classId is string &&
        data.title is string &&
        data.startAt is timestamp &&
        data.endAt is timestamp &&
        data.location is string &&
        data.status in ['scheduled', 'rescheduled', 'cancelled', 'completed'] &&
        data.note is string &&
        (data.makeUpForSessionId == null || data.makeUpForSessionId is string) &&
        hasTimestamps(data);
    }

    function validLessonPlanObjectives(data) {
      return data.keys().hasAll(['knowledge', 'skills', 'attitude']) &&
        data.keys().hasOnly(['knowledge', 'skills', 'attitude']) &&
        data.knowledge is string &&
        data.skills is string &&
        data.attitude is string;
    }

    function validLessonPlanPreparation(data) {
      return data.keys().hasAll(['teacher', 'student']) &&
        data.keys().hasOnly(['teacher', 'student']) &&
        data.teacher is string &&
        data.student is string;
    }

    function validLessonPlanDriveAttachment(data) {
      return (
        data.get('driveFileId', null) == null &&
        data.get('driveFileName', null) == null &&
        data.get('driveMimeType', null) == null &&
        data.get('driveWebViewLink', null) == null &&
        data.get('driveModifiedTime', null) == null
      ) || (
        data.driveFileId is string && data.driveFileId.size() <= 200 &&
        data.driveFileName is string && data.driveFileName.size() <= 300 &&
        data.driveMimeType is string && data.driveMimeType.size() <= 150 &&
        data.driveWebViewLink is string && data.driveWebViewLink.matches('https://.*') &&
        data.driveModifiedTime is string && data.driveModifiedTime.size() <= 50
      );
    }

    function validLessonPlanData(data) {
      return data.keys().hasAll(['title', 'classId', 'courseId', 'subjectId', 'sessionId', 'objectives', 'preparation', 'activities', 'homework', 'notesAfterTeaching', 'attachmentUrl', 'attachmentLabel', 'publicSummary', 'status', 'createdBy', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['title', 'classId', 'courseId', 'subjectId', 'sessionId', 'objectives', 'preparation', 'activities', 'homework', 'notesAfterTeaching', 'attachmentUrl', 'attachmentLabel', 'driveFileId', 'driveFileName', 'driveMimeType', 'driveWebViewLink', 'driveModifiedTime', 'publicSummary', 'status', 'createdBy', 'createdAt', 'updatedAt']) &&
        data.title is string &&
        (data.classId == null || data.classId is string) &&
        (data.courseId == null || data.courseId is string) &&
        (data.subjectId == null || data.subjectId is string) &&
        (data.sessionId == null || data.sessionId is string) &&
        validLessonPlanObjectives(data.objectives) &&
        validLessonPlanPreparation(data.preparation) &&
        data.activities is list &&
        data.homework is string &&
        data.notesAfterTeaching is string &&
        (data.attachmentUrl == null || data.attachmentUrl is string) &&
        data.attachmentLabel is string &&
        validLessonPlanDriveAttachment(data) &&
        data.publicSummary is string &&
        data.status in ['draft', 'published', 'archived'] &&
        hasTimestamps(data);
    }

    function validLessonPlanTemplateData(data) {
      return data.keys().hasAll(['name', 'objectives', 'preparation', 'activities', 'homework', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['name', 'objectives', 'preparation', 'activities', 'homework', 'createdAt', 'updatedAt']) &&
        data.name is string &&
        validLessonPlanObjectives(data.objectives) &&
        validLessonPlanPreparation(data.preparation) &&
        data.activities is list &&
        data.homework is string &&
        hasTimestamps(data);
    }

    function validScoreSource(data, scoreId) {
      return data.get('source', 'manual') in ['manual', 'assignment'] &&
        (
          (
            data.get('source', 'manual') == 'manual' &&
            data.get('assignmentId', null) == null &&
            data.get('submissionId', null) == null
          ) || (
            data.get('source', 'manual') == 'assignment' &&
            data.assessmentType == 'assignment' &&
            scoreId == 'assignment_' + data.assignmentId + '_' + data.studentId &&
            get(/databases/$(database)/documents/assignments/$(data.assignmentId)).data.classId == data.classId &&
            get(/databases/$(database)/documents/submissions/$(data.submissionId)).data.studentId == data.studentId &&
            get(/databases/$(database)/documents/submissions/$(data.submissionId)).data.assignmentId == data.assignmentId &&
            get(/databases/$(database)/documents/submissions/$(data.submissionId)).data.classId == data.classId
          )
        );
    }

    function validAssignmentData(data) {
      return data.keys().hasAll(['title', 'description', 'classId', 'lessonPlanId', 'sessionId', 'dueAt', 'submissionType', 'maxScore', 'status', 'createdBy', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['title', 'description', 'classId', 'subjectId', 'lessonPlanId', 'sessionId', 'dueAt', 'submissionType', 'maxScore', 'status', 'createdBy', 'createdAt', 'updatedAt']) &&
        data.title is string &&
        data.description is string &&
        data.classId is string &&
        (!data.keys().hasAny(['subjectId']) || data.subjectId is string) &&
        (data.lessonPlanId == null || data.lessonPlanId is string) &&
        (data.sessionId == null || data.sessionId is string) &&
        data.dueAt is timestamp &&
        data.submissionType in ['link', 'text'] &&
        data.maxScore is number && data.maxScore > 0 &&
        data.status in ['draft', 'published', 'closed'] &&
        data.createdBy is string &&
        hasTimestamps(data);
    }

    function validSubmissionData(data) {
      return data.keys().hasAll(['assignmentId', 'studentId', 'classId', 'submissionUrl', 'submissionText', 'studentNote', 'status', 'score', 'teacherComment', 'checkedBy', 'submittedAt', 'checkedAt', 'updatedAt']) &&
        data.keys().hasOnly(['assignmentId', 'studentId', 'classId', 'submissionUrl', 'submissionText', 'studentNote', 'status', 'score', 'teacherComment', 'checkedBy', 'submittedAt', 'checkedAt', 'updatedAt']) &&
        data.assignmentId is string &&
        data.studentId is string &&
        data.classId is string &&
        data.submissionUrl is string &&
        data.submissionText is string &&
        data.studentNote is string &&
        data.status in ['submitted', 'reviewing', 'graded', 'redo_required'] &&
        (data.score == null || data.score is number) &&
        data.teacherComment is string &&
        (data.checkedBy == null || data.checkedBy is string) &&
        data.submittedAt is timestamp &&
        (data.checkedAt == null || data.checkedAt is timestamp) &&
        data.updatedAt is timestamp;
    }

    function validAnnouncementData(data) {
      return data.keys().hasAll(['type', 'title', 'message', 'createdAt']) &&
        data.keys().hasOnly(['type', 'sessionId', 'assignmentId', 'classId', 'studentId', 'title', 'message', 'createdAt']) &&
        data.type in ['attendance_alert', 'schedule_change', 'homework_reminder'] &&
        data.title is string &&
        data.message is string &&
        (!data.keys().hasAny(['sessionId']) || data.sessionId is string) &&
        (!data.keys().hasAny(['assignmentId']) || data.assignmentId is string) &&
        (!data.keys().hasAny(['classId']) || data.classId is string) &&
        (!data.keys().hasAny(['studentId']) || data.studentId is string);
    }

    function validLessonPlanPublicData(data, lessonPlanId) {
      return data.keys().hasAll(['lessonPlanId', 'title', 'classId', 'courseId', 'subjectId', 'sessionId', 'publicSummary', 'publishedAt']) &&
        data.keys().hasOnly(['lessonPlanId', 'title', 'classId', 'courseId', 'subjectId', 'sessionId', 'publicSummary', 'publishedAt']) &&
        data.lessonPlanId == lessonPlanId &&
        data.title is string &&
        data.classId is string &&
        (data.courseId == null || data.courseId is string) &&
        (data.subjectId == null || data.subjectId is string) &&
        (data.sessionId == null || data.sessionId is string) &&
        data.publicSummary is string &&
        data.publishedAt is timestamp;
    }

    function validAttendanceSummary(data) {
      return data.keys().hasAll(['sessionId', 'classId', 'total', 'present', 'absent', 'late', 'excused', 'updatedAt']) &&
        data.keys().hasOnly(['sessionId', 'classId', 'total', 'present', 'absent', 'late', 'excused', 'updatedAt']) &&
        data.sessionId is string && data.classId is string && data.updatedAt is timestamp &&
        data.total is int && data.total >= 0 &&
        data.present is int && data.present >= 0 &&
        data.absent is int && data.absent >= 0 &&
        data.late is int && data.late >= 0 &&
        data.excused is int && data.excused >= 0 &&
        data.total == data.present + data.absent + data.late + data.excused;
    }

    function validAssignmentSummary(data) {
      return data.keys().hasAll(['assignmentId', 'totalStudents', 'submittedCount', 'gradedCount', 'redoCount', 'updatedAt']) &&
        data.keys().hasOnly(['assignmentId', 'totalStudents', 'submittedCount', 'gradedCount', 'redoCount', 'updatedAt']) &&
        data.assignmentId is string && data.updatedAt is timestamp &&
        data.totalStudents is int && data.totalStudents >= 0 &&
        data.submittedCount is int && data.submittedCount >= 0 && data.submittedCount <= data.totalStudents &&
        data.gradedCount is int && data.gradedCount >= 0 && data.gradedCount <= data.totalStudents &&
        data.redoCount is int && data.redoCount >= 0 && data.redoCount <= data.totalStudents;
    }

    function validStudentSummary(data) {
      return data.keys().hasAll(['studentId', 'scoreCount', 'averagePercent', 'latestScore', 'latestMaxScore', 'updatedAt']) &&
        data.keys().hasOnly(['studentId', 'scoreCount', 'totalPercent', 'averagePercent', 'latestScore', 'latestMaxScore', 'updatedAt']) &&
        data.studentId is string && data.updatedAt is timestamp &&
        data.scoreCount is int && data.scoreCount >= 0 &&
        data.averagePercent is number && data.averagePercent >= 0 && data.averagePercent <= 100 &&
        (!data.keys().hasAny(['totalPercent']) || (data.totalPercent is number && data.totalPercent >= 0)) &&
        data.latestMaxScore is number && data.latestMaxScore > 0 &&
        data.latestScore is number && data.latestScore >= 0 && data.latestScore <= data.latestMaxScore;
    }

    function validPaymentData(data) {
      return data.keys().hasAll(['invoiceId', 'studentId', 'amount', 'transactionReference', 'note', 'status', 'reportedBy', 'verifiedBy', 'reportedAt', 'verifiedAt', 'updatedAt']) &&
        data.keys().hasOnly(['invoiceId', 'studentId', 'amount', 'transactionReference', 'note', 'status', 'reportedBy', 'verifiedBy', 'reportedAt', 'verifiedAt', 'updatedAt']) &&
        data.invoiceId is string &&
        data.studentId is string &&
        data.amount is number && data.amount > 0 &&
        data.transactionReference is string &&
        data.note is string &&
        data.status in ['reported', 'verified', 'rejected'] &&
        data.reportedBy is string &&
        (data.verifiedBy == null || data.verifiedBy is string) &&
        data.reportedAt is timestamp &&
        (data.verifiedAt == null || data.verifiedAt is timestamp) &&
        data.updatedAt is timestamp;
    }

    // ---------- users/{uid} ----------
    // Chi Admin duoc doi role/studentIds/status. Tao ho so lan dau (claim invite)
    // phai khop dung role/studentIds lay tu invite - nguoi dung khong tu chon (A16.4).

    match /users/{uid} {
      // Teacher can read the operational directory needed by class and parent
      // views, but Admin profiles remain private from Teacher accounts.
      allow read: if isAdmin() || request.auth.uid == uid || (
        isTeacher() && resource.data.role in ['teacher', 'viewer']
      );

      allow create: if isAdmin() || (
        request.auth.uid == uid &&
        hasActiveInvite() &&
        request.resource.data.email == requesterEmail() &&
        request.resource.data.role == inviteForRequester().role &&
        request.resource.data.studentIds == inviteForRequester().studentIds &&
        request.resource.data.status == 'active' &&
        request.resource.data.keys().hasOnly(
          ['email', 'displayName', 'photoURL', 'role', 'studentIds', 'status', 'createdAt', 'updatedAt']
        )
      );

      allow update: if isAdmin() || (
        request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'photoURL', 'lastLoginAt', 'notificationPrefs', 'updatedAt']) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.studentIds == resource.data.studentIds &&
        request.resource.data.status == resource.data.status
      );

      allow delete: if false;
    }

    // ---------- invites/{normalizedEmail} ----------
    // Chi Admin tao/sua/xoa loi moi. Nguoi duoc moi chi duoc doc loi moi cua
    // chinh email da xac thuc, va chi duoc cap nhat status active -> claimed
    // khi claim (khong duoc tu doi role/studentIds/email cua loi moi) (A16.4).

    match /invites/{email} {
      allow read: if isAdmin() || (
        hasVerifiedEmail() && requesterEmail() == email
      );

      allow create: if isAdmin() &&
        request.resource.data.email == email &&
        isValidRole(request.resource.data.role) &&
        request.resource.data.status == 'active';

      allow update: if isAdmin() || (
        hasVerifiedEmail() &&
        requesterEmail() == email &&
        resource.data.status == 'active' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'claimedAt']) &&
        request.resource.data.status == 'claimed'
      );

      allow delete: if isAdmin();
    }

    // ---------- legacy client telemetry ----------
    // Existing records stay readable by Admin for migration/audit, but clients
    // can no longer create noisy self-reported telemetry.
    match /account_activity/{activityId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- settings/* ----------
    // Integration identifiers are public config for active staff. Other settings remain Admin-only.
    match /settings/{docId} {
      allow read: if isAdmin() ||
        (docId == 'integrations' && isStaff()) ||
        (docId == 'academic' && isActive());
      allow create, update: if isAdmin() && (
        (docId == 'general' && validGeneralSettings(request.resource.data)) ||
        (docId == 'academic' && validAcademicSettings(request.resource.data)) ||
        (docId == 'integrations' && validIntegrationSettings(request.resource.data)) ||
        (docId == 'payment' && validPaymentSettings(request.resource.data)) ||
        (docId == 'messenger')
      );
      allow delete: if false;
    }

    match /usage_events/{usageId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- audit_logs/{logId} ----------
    // Staff duoc ghi (khong duoc sua/xoa - bat bien), chi Admin duoc xem (A26).

    match /audit_logs/{logId} {
      allow read: if isAdmin();

      allow create: if isStaff() &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.keys().hasOnly(
          ['action', 'actorUid', 'actorEmail', 'targetType', 'targetId', 'meta', 'createdAt']
        );

      allow update, delete: if false;
    }

    // ---------- subjects/{subjectId} ----------
    // Staff CRUD (khong xoa cung - dung status=archived, A27). Danh muc mon
    // hoc khong nhay cam theo tung hoc sinh nen moi nguoi dung active deu
    // doc duoc (Phase 3, phuc vu Portal Phase 10 ve sau).

    match /subjects/{subjectId} {
      allow read: if isActive();
      allow create: if isStaff() &&
        request.resource.data.status == 'active' &&
        validSubjectData(subjectId, request.resource.data);
      allow update: if isStaff() &&
        validSubjectData(subjectId, request.resource.data) &&
        keepsImmutable(['code', 'createdAt']);
      allow delete: if false;
    }

    // ---------- courses/{courseId} ----------
    // Staff CRUD. Danh muc khoa hoc khong nhay cam theo tung hoc sinh nen
    // moi nguoi dung active deu doc duoc (Phase 3).

    match /courses/{courseId} {
      allow read: if isActive();
      allow create: if isStaff() &&
        validCourseData(request.resource.data);
      allow update: if isStaff() &&
        validCourseData(request.resource.data) &&
        keepsImmutable(['createdAt']);
      allow delete: if false;
    }

    // ---------- students/{studentId} ----------
    // Staff CRUD. Viewer chi doc duoc ho so hoc sinh minh so huu qua
    // ownsStudent() (A11 - quy tac ownership, khong dua tren du lieu Viewer
    // tu sua duoc).

    match /students/{studentId} {
      allow read: if isStaff() || ownsStudent(studentId);
      allow create: if isAdmin() &&
        validStudentData(studentId, request.resource.data);
      allow update: if keepsImmutable(['studentCode', 'createdAt']) &&
        validStudentData(studentId, request.resource.data) &&
        (
          isAdmin() || (
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['currentClassIds', 'teacherIds']) &&
            isTeacherEnrollmentStudentUpdate(studentId)
          ) || (
            isTeacher() &&
            request.auth.uid in resource.data.teacherIds &&
            request.resource.data.teacherIds == resource.data.teacherIds &&
            request.resource.data.currentClassIds == resource.data.currentClassIds &&
            request.resource.data.parentUids == resource.data.parentUids
          )
        );
      allow delete: if false;
    }

    // ---------- classes/{classId} ----------
    // Staff CRUD. Viewer chi doc lop co studentIds giao voi studentIds cua
    // minh (A11). Ghi danh (them/bot studentIds) chi thuc hien qua
    // enrollments/{classId_studentId} de dong bo hai chieu voi
    // students/{id}.currentClassIds (xem services/firestore/enrollments.ts).

    match /classes/{classId} {
      // Use resource data here so Firestore can prove an array-contains list
      // query. isAssignedTeacherForClass() uses get() and is for child records.
      allow read: if isAdmin() ||
        (isTeacher() && request.auth.uid in resource.data.teacherIds) ||
        (isActive() && currentUser().role == 'viewer' &&
         resource.data.studentIds.hasAny(currentUser().studentIds));
      allow create: if (
        isAdmin() ||
        (
          isTeacher() &&
          request.resource.data.teacherIds.size() == 1 &&
          request.resource.data.teacherIds[0] == request.auth.uid &&
          request.resource.data.studentIds.size() == 0
        )
      ) &&
        validClassData(request.resource.data);
      allow update: if keepsImmutable(['createdAt']) &&
        validClassData(request.resource.data) &&
        (
          isAdmin() ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['studentIds']) &&
            isTeacherEnrollmentClassUpdate(classId)
          ) ||
          (
            isAssignedTeacherForClass(classId) &&
            request.resource.data.teacherIds == resource.data.teacherIds &&
            request.resource.data.studentIds == resource.data.studentIds
          )
        );
      allow delete: if false;
    }

    // ---------- enrollments/{classId_studentId} ----------
    // ID xac dinh {classId}_{studentId} chong ghi trung (A13). Staff CRUD;
    // Viewer chi doc ghi danh cua hoc sinh minh so huu.

    match /enrollments/{enrollmentId} {
      allow read: if canManageClass(resource.data.classId) || ownsStudent(resource.data.studentId);
      allow create: if (
        isAdmin() &&
        enrollmentId == request.resource.data.classId + '_' + request.resource.data.studentId &&
        request.resource.data.status in ['active', 'ended']
      ) || isTeacherEnrollmentCreate(enrollmentId);
      allow update: if isAdmin() &&
        request.resource.data.status in ['active', 'ended'] &&
        keepsImmutable(['classId', 'courseId', 'studentId', 'joinedAt']);
      allow delete: if false;
    }

    match /sessions/{sessionId} {
      allow read: if canManageClass(resource.data.classId) || (
        isActive() && currentUser().role == 'viewer' &&
        get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.studentIds
          .hasAny(currentUser().studentIds)
      );
      allow create: if canManageClass(request.resource.data.classId) &&
        validSessionData(request.resource.data);
      allow update: if canManageClass(resource.data.classId) &&
        validSessionData(request.resource.data) &&
        keepsImmutable(['classId', 'createdAt']);
      allow delete: if false;
    }

    match /announcements/{announcementId} {
      allow read: if isStaff() || (
        isActive() && resource.data.studentId != null && ownsStudent(resource.data.studentId)
      );
      allow create: if isStaff() && validAnnouncementData(request.resource.data);
      allow update: if isStaff() &&
        validAnnouncementData(request.resource.data) &&
        resource.data.type == 'attendance_alert' &&
        announcementId == 'attendance_' + resource.data.sessionId + '_' + resource.data.studentId &&
        keepsImmutable(['type', 'sessionId', 'classId', 'studentId']) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'message', 'createdAt']);
      allow delete: if false;
    }

    match /notification_reads/{readId} {
      allow read: if isAdmin() || (
        isActive() && resource.data.uid == request.auth.uid
      );
      allow create, update: if isActive() &&
        request.resource.data.keys().hasOnly(['uid', 'announcementId', 'readAt']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.announcementId is string &&
        request.resource.data.readAt is timestamp &&
        readId == request.auth.uid + '_' + request.resource.data.announcementId &&
        ownsStudent(
          get(/databases/$(database)/documents/announcements/$(request.resource.data.announcementId)).data.studentId
        );
      allow delete: if false;
    }

    match /lesson_plans/{lessonPlanId} {
      // Nguoi tao luon doc lai duoc giao an cua chinh minh, ke ca khi chua gan lop (classId == null) - sua loi cu.
      allow read: if isAdmin() ||
        (resource.data.classId != null && isAssignedTeacherForClass(resource.data.classId)) ||
        resource.data.createdBy == request.auth.uid;
      allow create: if (isAdmin() || (request.resource.data.classId != null && isAssignedTeacherForClass(request.resource.data.classId))) &&
        request.resource.data.createdBy == request.auth.uid &&
        validLessonPlanData(request.resource.data);
      allow update: if (isAdmin() || (resource.data.classId != null && isAssignedTeacherForClass(resource.data.classId))) &&
        validLessonPlanData(request.resource.data) &&
        keepsImmutable(['classId', 'createdBy', 'createdAt']);
      allow delete: if false;
    }

    match /lesson_plan_public/{lessonPlanId} {
      allow read: if canManageClass(resource.data.classId) || (
        isActive() && currentUser().role == 'viewer' &&
        get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.studentIds
          .hasAny(currentUser().studentIds)
      );
      allow create: if canManageClass(request.resource.data.classId) && validLessonPlanPublicData(request.resource.data, lessonPlanId);
      allow update: if canManageClass(resource.data.classId) &&
        validLessonPlanPublicData(request.resource.data, lessonPlanId) &&
        keepsImmutable(['lessonPlanId', 'classId']);
      allow delete: if canManageClass(resource.data.classId);
    }

    match /lesson_plan_templates/{templateId} {
      allow read: if isStaff();
      allow create: if isStaff() && validLessonPlanTemplateData(request.resource.data);
      allow update: if isStaff() && validLessonPlanTemplateData(request.resource.data) && keepsImmutable(['createdAt']);
      allow delete: if false;
    }

    match /attendance/{attendanceId} {
      allow read: if canManageClass(resource.data.classId) || ownsStudent(resource.data.studentId);
      allow create: if canManageClass(request.resource.data.classId) &&
        attendanceId == request.resource.data.sessionId + '_' + request.resource.data.studentId &&
        request.resource.data.status in ['present', 'absent', 'late', 'excused'];
      allow update: if canManageClass(resource.data.classId) &&
        request.resource.data.status in ['present', 'absent', 'late', 'excused'] &&
        keepsImmutable(['sessionId', 'classId', 'studentId']);
      allow delete: if false;
    }

    match /attendance_summaries/{sessionId} {
      allow read: if canManageClass(resource.data.classId) || (
        isActive() && currentUser().role == 'viewer' &&
        get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.studentIds
          .hasAny(currentUser().studentIds)
      );
      allow create: if canManageClass(request.resource.data.classId) &&
        request.resource.data.sessionId == sessionId && validAttendanceSummary(request.resource.data);
      allow update: if canManageClass(resource.data.classId) &&
        request.resource.data.sessionId == sessionId &&
        validAttendanceSummary(request.resource.data) &&
        keepsImmutable(['sessionId', 'classId']);
      allow delete: if false;
    }

    match /assignments/{assignmentId} {
      allow read: if canManageClass(resource.data.classId) || (
        isActive() && currentUser().role == 'viewer' && resource.data.status == 'published' &&
        get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.studentIds.hasAny(currentUser().studentIds)
      );
      allow create: if canManageClass(request.resource.data.classId) &&
        request.resource.data.createdBy == request.auth.uid &&
        validAssignmentData(request.resource.data);
      allow update: if canManageClass(resource.data.classId) &&
        validAssignmentData(request.resource.data) &&
        keepsImmutable(['classId', 'createdBy', 'createdAt']);
      allow delete: if false;
    }
    match /submissions/{submissionId} {
      allow read: if canManageClass(resource.data.classId) || ownsStudent(resource.data.studentId);
      allow create: if ownsStudent(request.resource.data.studentId) &&
        submissionId == request.resource.data.assignmentId + '_' + request.resource.data.studentId &&
        request.resource.data.status == 'submitted' && request.resource.data.score == null && request.resource.data.teacherComment == '' &&
        validSubmissionData(request.resource.data) &&
        get(/databases/$(database)/documents/assignments/$(request.resource.data.assignmentId)).data.classId == request.resource.data.classId;
      allow update: if keepsImmutable(['assignmentId', 'studentId', 'classId']) &&
        validSubmissionData(request.resource.data) &&
        (
          (
            canManageClass(resource.data.classId) &&
            request.resource.data.status in ['submitted', 'reviewing', 'graded', 'redo_required'] &&
            request.resource.data.checkedBy == request.auth.uid &&
            (
              request.resource.data.score == null ||
              (
                request.resource.data.score >= 0 &&
                request.resource.data.score <= get(/databases/$(database)/documents/assignments/$(resource.data.assignmentId)).data.maxScore
              )
            )
          ) || (
            ownsStudent(resource.data.studentId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['submissionUrl', 'submissionText', 'studentNote', 'status', 'submittedAt', 'updatedAt']) &&
            request.resource.data.status == 'submitted'
          )
        );
      allow delete: if false;
    }
    match /assignment_summaries/{assignmentId} {
      allow read: if isAdmin() || (
        isTeacher() && canManageClass(
          get(/databases/$(database)/documents/assignments/$(assignmentId)).data.classId
        )
      );
      allow create: if request.resource.data.assignmentId == assignmentId &&
        canManageClass(
          getAfter(/databases/$(database)/documents/assignments/$(assignmentId)).data.classId
        ) &&
        validAssignmentSummary(request.resource.data);
      allow update: if canManageClass(
          get(/databases/$(database)/documents/assignments/$(assignmentId)).data.classId
        ) &&
        request.resource.data.assignmentId == assignmentId &&
        validAssignmentSummary(request.resource.data) &&
        keepsImmutable(['assignmentId']);
      allow delete: if false;
    }
    match /scores/{scoreId} {
      allow read: if canManageClass(resource.data.classId) ||
        (ownsStudent(resource.data.studentId) && resource.data.get('published', true));
      allow create: if canManageClass(request.resource.data.classId) &&
        request.resource.data.maxScore > 0 &&
        request.resource.data.score >= 0 && request.resource.data.score <= request.resource.data.maxScore &&
        validScoreSource(request.resource.data, scoreId);
      allow update: if canManageClass(resource.data.classId) &&
        request.resource.data.maxScore > 0 &&
        request.resource.data.score >= 0 && request.resource.data.score <= request.resource.data.maxScore &&
        validScoreSource(request.resource.data, scoreId) &&
        request.resource.data.get('source', 'manual') == resource.data.get('source', 'manual') &&
        request.resource.data.get('assignmentId', null) == resource.data.get('assignmentId', null) &&
        request.resource.data.get('submissionId', null) == resource.data.get('submissionId', null) &&
        keepsImmutable(['studentId', 'classId', 'subjectId', 'assessmentName', 'assessmentType', 'createdBy', 'createdAt']);
      allow delete: if false;
    }
    match /student_summaries/{studentId} {
      allow read: if isAdmin() || isAssignedTeacherForStudent(studentId) || ownsStudent(studentId);
      allow create: if (isAdmin() || isAssignedTeacherForStudent(studentId)) && request.resource.data.studentId == studentId &&
        validStudentSummary(request.resource.data);
      allow update: if (isAdmin() || isAssignedTeacherForStudent(studentId)) &&
        request.resource.data.studentId == studentId &&
        validStudentSummary(request.resource.data) &&
        keepsImmutable(['studentId']);
      allow delete: if false;
    }
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || ownsStudent(resource.data.studentId) ||
        isAssignedTeacherForStudent(resource.data.studentId);
      allow create: if isAdmin() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'unpaid' &&
        request.resource.data.amount > 0;
      allow update: if keepsImmutable(
        ['invoiceCode', 'studentId', 'courseId', 'amount', 'paymentContent', 'bankBin', 'accountNumber', 'accountName', 'createdBy', 'createdAt']
      ) && (
        isAdmin() || (
          ownsStudent(resource.data.studentId) && resource.data.status in ['unpaid', 'rejected'] &&
          request.resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        )
      );
      allow delete: if false;
    }
    match /payments/{paymentId} {
      allow read: if isAdmin() || ownsStudent(resource.data.studentId) ||
        isAssignedTeacherForStudent(resource.data.studentId);
      allow create: if ownsStudent(request.resource.data.studentId) &&
        request.resource.data.status == 'reported' &&
        request.resource.data.reportedBy == request.auth.uid &&
        request.resource.data.verifiedBy == null &&
        validPaymentData(request.resource.data) &&
        get(/databases/$(database)/documents/invoices/$(request.resource.data.invoiceId)).data.amount == request.resource.data.amount;
      allow update: if validPaymentData(request.resource.data) && ((isAdmin() &&
        request.resource.data.status in ['verified', 'rejected'] &&
        keepsImmutable(['invoiceId', 'studentId', 'amount', 'reportedBy', 'reportedAt'])
      ) || (
        ownsStudent(resource.data.studentId) &&
        resource.data.status == 'rejected' &&
        resource.data.reportedBy == request.auth.uid &&
        request.resource.data.status == 'reported' &&
        request.resource.data.reportedBy == request.auth.uid &&
        request.resource.data.invoiceId == resource.data.invoiceId &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.amount == resource.data.amount &&
        request.resource.data.verifiedBy == null &&
        request.resource.data.verifiedAt == null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['transactionReference', 'note', 'status', 'verifiedBy', 'verifiedAt', 'reportedAt', 'updatedAt']
        )
      ));
      allow delete: if false;
    }
    match /chat_threads/{threadId} {
      allow read: if isAdmin() || (
        isTeacher() && request.auth.uid in resource.data.assignedTeacherIds
      );
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isAdmin() || (
          isTeacher() && request.auth.uid in
            get(/databases/$(database)/documents/chat_threads/$(threadId)).data.assignedTeacherIds
        );
        allow create, update, delete: if false;
      }
    }

    match /message_outbox/{messageId} {
      allow read: if isAdmin() || (
        isTeacher() && resource.data.actorUid == request.auth.uid
      );
      allow create, update, delete: if false;
    }
    match /messenger_connections/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow write: if false;
    }

    // Nonce va reverse-index chi Worker voi service account duoc truy cap.
    match /messenger_link_nonces/{nonceId} {
      allow read, write: if false;
    }

    match /messenger_psid_links/{psid} {
      allow read, write: if false;
    }

    // fanpage_posts: lich su + hang cho dang bai Fanpage - client ghi truc tiep (Admin-only,
    // Worker khong co endpoint ghi log). imageUrls chi la chuoi URL cong khai, khong co file.
    match /fanpage_posts/{postId} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.message is string && request.resource.data.message.size() > 0 &&
        request.resource.data.status in ['sent', 'failed', 'scheduled'] &&
        (request.resource.data.imageUrls == null ||
          (request.resource.data.imageUrls is list && request.resource.data.imageUrls.size() <= 4));
      allow update: if isAdmin() &&
        resource.data.status == 'scheduled' &&
        request.resource.data.status in ['sent', 'failed', 'canceled'] &&
        keepsImmutable(['message', 'link', 'imageUrls', 'actorUid', 'actorName', 'createdAt', 'scheduledFor']);
      allow delete: if false;
    }

    // ---------- Mac dinh: tu choi tat ca ----------
    // Cac collection khac (sessions, lesson_plans, attendance, assignments,
    // submissions, scores, invoices, payments, announcements...) se duoc mo
    // dan theo Phase 4-11, kem Emulator test cho tung quyen truoc khi
    // enable (A28).

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
